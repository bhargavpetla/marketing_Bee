# =============================================================
# Required — set in Render dashboard or local .env.local
# =============================================================

# Anthropic API key (used internally for analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Apify token — used to scrape Meta Ad Library + Google Ads Transparency
APIFY_TOKEN=apify_api_...

# Apify actor slugs (override if you swap to different actors)
APIFY_ACTOR_META=leadsbrary/meta-ads-library-scraper
APIFY_ACTOR_GOOGLE=solidcode/ads-transparency-scraper

# =============================================================
# Optional — Render persistent-disk setup (Starter plan only)
# =============================================================
# When mounting a disk at /var/data, point SQLite + scraped images at it
# so they survive redeploys.
#
# DATA_DIR=/var/data
# SCRAPED_DIR=/var/data/scraped
# SCRAPED_PUBLIC_PATH=/scraped     # only change if scraped dir is OUTSIDE /public
